          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS active_associates\r\nFROM destro_associates.associates\r\nWHERE is_active = true\r\n  AND UPPER(first_name) != 'ADMIN'\r\n  AND UPPER(last_name) != 'ADMIN'\r\n  AND LENGTH(associate_id) < 36;\r\n",
