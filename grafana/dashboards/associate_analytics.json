          "rawSql": "SELECT\n  s.recorded_at AS \"Time\",\n  s.associate_id AS \"Associate ID\",\n  s.event_type AS \"Event\"\nFROM destro_core.associate_sessions s\nJOIN destro_associates.associates a ON a.associate_id = s.associate_id\nWHERE $__timeFilter(s.recorded_at)\n  AND UPPER(a.first_name) != 'ADMIN'\n  AND UPPER(a.last_name) != 'ADMIN'\n  AND LENGTH(a.associate_id) < 36\nORDER BY s.recorded_at DESC;\n",
