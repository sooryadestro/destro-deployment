          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  acm.recorded_at AS \"Timestamp\",\n  acm.associate_id AS \"Associate ID\",\n  acm.cart_id AS \"Cart\",\n  acm.starting_location AS \"Starting Location\",\n  acm.starting_door AS \"Starting Door\",\n  acm.destination AS \"Destination\"\nFROM destro_core.associate_cart_moves acm\nJOIN destro_associates.associates a ON a.associate_id = acm.associate_id\nWHERE $__timeFilter(acm.recorded_at)\n  AND UPPER(a.first_name) != 'ADMIN'\n  AND UPPER(a.last_name) != 'ADMIN'\n  AND LENGTH(a.associate_id) < 36\nORDER BY acm.recorded_at DESC;\n",
