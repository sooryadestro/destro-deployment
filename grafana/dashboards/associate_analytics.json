      "pluginVersion": "12.4.1",
      "targets": [
        {
          "dataset": "destro_yusen_db",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "grafana-postgresql-datasource"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    a.associate_id AS \"Associate ID\",\r\n    a.first_name AS \"First Name\",\r\n    a.last_name AS \"Last Name\",\r\n    CASE WHEN a.is_active THEN 'Active' ELSE 'Deactivated' END AS \"Account\",\r\n    CASE\r\n      WHEN last_session.event_type = 'Login' THEN 'Online'\r\n      ELSE 'Offline'\r\n    END AS \"Status\",\r\n    COALESCE(unload.total, 0) AS \"No. of Carts Unloaded\",\r\n    COALESCE(runs.total, 0) AS \"No. of Runner Trips\",\r\n    COALESCE(load.total, 0) AS \"No. of Carts Loaded\"\r\nFROM destro_associates.associates a\r\nLEFT JOIN (\r\n    SELECT DISTINCT ON (associate_id)\r\n      associate_id, event_type\r\n    FROM destro_core.associate_sessions\r\n    ORDER BY associate_id, recorded_at DESC\r\n) last_session ON last_session.associate_id = a.associate_id\r\nLEFT JOIN (\r\n    SELECT DISTINCT ON (associate_id) associate_id, trips AS total\r\n    FROM destro_core.runner_trips\r\n    WHERE $__timeFilter(recorded_at)\r\n    ORDER BY associate_id, recorded_at DESC\r\n) runs ON runs.associate_id = a.associate_id\r\nLEFT JOIN (\r\n    SELECT associate_id, COUNT(*) AS total\r\n    FROM destro_core.associate_cart_moves\r\n    WHERE $__timeFilter(recorded_at)\r\n      AND action_type = 'Unload'\r\n    GROUP BY associate_id\r\n) unload ON unload.associate_id = a.associate_id\r\nLEFT JOIN (\r\n    SELECT associate_id, COUNT(*) AS total\r\n    FROM destro_core.associate_cart_moves\r\n    WHERE $__timeFilter(recorded_at)\r\n      AND action_type = 'Load'\r\n    GROUP BY associate_id\r\n) load ON load.associate_id = a.associate_id\r\nWHERE UPPER(a.first_name) != 'ADMIN'\r\n  AND UPPER(a.last_name) != 'ADMIN'\r\n  AND LENGTH(a.associate_id) < 36\r\nORDER BY a.first_name;\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
